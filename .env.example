# Copy to .env and adjust. Single env file for the whole repo.

# --- Database ---
# Local dev (matches docker-compose.yml):
DATABASE_URL="postgresql://pokerpoker:pokerpoker@localhost:5432/pokerpoker?schema=public"
# On Render, set this to the Internal Database URL from your Render Postgres.

# --- Server ---
PORT=3001
# Generate a long random string for production (e.g. `openssl rand -hex 32`).
JWT_SECRET="dev-secret-change-me"

# --- ML (chip/tip counting + chip identify) ---
# Server-side Anthropic API key (vision). Leave blank to disable photo counting.
VISION_API_KEY=""
# Vision model. Defaults to claude-opus-4-8 (most accurate). Override if needed,
# e.g. VISION_MODEL="claude-sonnet-4-6" for lower cost/latency.
VISION_MODEL="claude-opus-4-8"
