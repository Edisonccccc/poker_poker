// PokerPoker data model — source of truth alongside docs/02-data-model.md.
// Postgres via Prisma. Money/chips use Decimal(12,2); app treats as integers
// (whole dollars) unless a table sets usesCents. Photos are stored in Postgres
// as bytea (Photo.data).
//
// NOTE: Prisma can't express CHECK constraints or views. They live in
// prisma/sql/constraints_and_views.sql (idempotent) and are applied with
// `npm run db:sql` after migrate (and on every Render deploy). Keep that file in
// sync with this schema. See docs/02-data-model.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  host
}

enum GameType {
  texas_holdem
  blackjack
}

enum GameStatus {
  open
  closed
}

enum TableStatus {
  open
  closed
}

enum SessionStatus {
  active
  checked_out
}

enum LedgerType {
  buy_in
  reimbursement
  tip
  adjustment
  payment
}

enum PartyType {
  player
  dealer
  other
}

// Host / admin account. Replaces Supabase auth.users + profiles: holds
// credentials for our own JWT email/password auth.
model User {
  id             String   @id @default(uuid()) @db.Uuid
  email          String   @unique
  passwordHash   String   @map("password_hash")
  displayName    String   @map("display_name")
  role           UserRole @default(host)
  faceDescriptor Float[]  @map("face_descriptor") // optional host face-unlock
  createdAt      DateTime @default(now()) @map("created_at")

  players Player[]
  dealers Dealer[]
  games   Game[]

  @@map("users")
}

// Image blob stored in Postgres (bytea).
model Photo {
  id        String   @id @default(uuid()) @db.Uuid
  data      Bytes
  mimeType  String   @map("mime_type")
  createdAt DateTime @default(now()) @map("created_at")

  playerAvatars Player[]           @relation("PlayerPhoto")
  dealerAvatars Dealer[]           @relation("DealerPhoto")
  chipRefs      ChipDenomination[] @relation("ChipRef")
  chipEdges     ChipDenomination[] @relation("ChipEdge")
  chipCounts    PlayerSession[]

  @@map("photos")
}

// Reusable player profile, owned by a host.
model Player {
  id             String   @id @default(uuid()) @db.Uuid
  hostId         String   @map("host_id") @db.Uuid
  name           String
  photoId        String?  @map("photo_id") @db.Uuid
  roles          String[] @default([]) // player / dealer / host / admin
  faceDescriptor Float[]  @map("face_descriptor") // 128-d for check-in matching
  createdAt      DateTime @default(now()) @map("created_at")

  host       User            @relation(fields: [hostId], references: [id], onDelete: Cascade)
  photo      Photo?          @relation("PlayerPhoto", fields: [photoId], references: [id])
  sessions   PlayerSession[]
  insurances Insurance[]

  @@index([hostId])
  @@map("players")
}

// Reusable dealer profile, owned by a host.
model Dealer {
  id             String   @id @default(uuid()) @db.Uuid
  hostId         String   @map("host_id") @db.Uuid
  name           String
  photoId        String?  @map("photo_id") @db.Uuid
  roles          String[] @default([]) // player / dealer / host / admin
  faceDescriptor Float[]  @map("face_descriptor")
  createdAt      DateTime @default(now()) @map("created_at")

  host     User            @relation(fields: [hostId], references: [id], onDelete: Cascade)
  photo    Photo?          @relation("DealerPhoto", fields: [photoId], references: [id])
  sessions DealerSession[]

  @@index([hostId])
  @@map("dealers")
}

// A day's session under a host.
model Game {
  id           String     @id @default(uuid()) @db.Uuid
  hostId       String     @map("host_id") @db.Uuid
  label        String?
  gameDate     DateTime   @default(now()) @map("game_date") @db.Date
  startedAt    DateTime   @default(now()) @map("started_at")
  status       GameStatus @default(open)
  retainPhotos Boolean?   @map("retain_photos") // chip-photo retention choice at settlement
  createdAt    DateTime   @default(now()) @map("created_at")

  host        User         @relation(fields: [hostId], references: [id], onDelete: Cascade)
  tables      Table[]
  hostCosts   HostCost[]
  settlements Settlement[]
  insurances  Insurance[]

  @@index([hostId, gameDate])
  @@map("games")
}

// A table within a game.
model Table {
  id        String      @id @default(uuid()) @db.Uuid
  gameId    String      @map("game_id") @db.Uuid
  type      GameType
  stakes    String? // e.g. "1/3", "25/50"
  label     String?
  usesCents Boolean     @default(false) @map("uses_cents")
  openedAt  DateTime    @default(now()) @map("opened_at")
  closedAt  DateTime?   @map("closed_at")
  status    TableStatus @default(open)
  createdAt DateTime    @default(now()) @map("created_at")

  game           Game               @relation(fields: [gameId], references: [id], onDelete: Cascade)
  denominations  ChipDenomination[]
  playerSessions PlayerSession[]
  dealerSessions DealerSession[]
  ledgerEntries  LedgerEntry[]

  @@index([gameId])
  @@map("tables")
}

// Per-table chip color -> value, locked at table creation.
model ChipDenomination {
  id         String   @id @default(uuid()) @db.Uuid
  tableId    String   @map("table_id") @db.Uuid
  color       String
  value       Decimal  @db.Decimal(12, 2)
  refPhotoId  String?  @map("ref_photo_id") @db.Uuid // face photo
  edgePhotoId String?  @map("edge_photo_id") @db.Uuid // side/edge photo
  createdAt   DateTime @default(now()) @map("created_at")

  table     Table  @relation(fields: [tableId], references: [id], onDelete: Cascade)
  refPhoto  Photo? @relation("ChipRef", fields: [refPhotoId], references: [id])
  edgePhoto Photo? @relation("ChipEdge", fields: [edgePhotoId], references: [id])

  @@unique([tableId, color])
  @@map("chip_denominations")
}

// A player seated at a table.
model PlayerSession {
  id          String        @id @default(uuid()) @db.Uuid
  tableId     String        @map("table_id") @db.Uuid
  playerId    String        @map("player_id") @db.Uuid
  checkinAt   DateTime      @default(now()) @map("checkin_at")
  checkoutAt  DateTime?     @map("checkout_at")
  chipsOut    Decimal?      @map("chips_out") @db.Decimal(12, 2)
  chipMethod  String?       @map("chip_method") // 'manual' | 'photo'
  chipPhotoId String?       @map("chip_photo_id") @db.Uuid
  hourlyReturn Boolean      @default(false) @map("hourly_return") // comp player for time
  hourlyRate  Decimal       @default(25) @map("hourly_rate") @db.Decimal(12, 2)
  status      SessionStatus @default(active)
  note        String?
  createdAt   DateTime      @default(now()) @map("created_at")

  table     Table         @relation(fields: [tableId], references: [id], onDelete: Cascade)
  player    Player        @relation(fields: [playerId], references: [id])
  chipPhoto Photo?        @relation(fields: [chipPhotoId], references: [id])
  ledger    LedgerEntry[]

  @@index([tableId])
  @@map("player_sessions")
}

// A dealer working a table.
model DealerSession {
  id         String        @id @default(uuid()) @db.Uuid
  tableId    String        @map("table_id") @db.Uuid
  dealerId   String        @map("dealer_id") @db.Uuid
  checkinAt  DateTime      @default(now()) @map("checkin_at")
  checkoutAt DateTime?     @map("checkout_at")
  tipsTotal  Decimal?      @map("tips_total") @db.Decimal(12, 2)
  tipsMethod String?       @map("tips_method") // 'manual' | 'photo'
  status     SessionStatus @default(active)
  note       String?
  createdAt  DateTime      @default(now()) @map("created_at")

  table  Table         @relation(fields: [tableId], references: [id], onDelete: Cascade)
  dealer Dealer        @relation(fields: [dealerId], references: [id])
  ledger LedgerEntry[]

  @@index([tableId])
  @@map("dealer_sessions")
}

// Unified money ledger. Exactly one of player/dealer session is set
// (enforced by a CHECK added in the migration).
model LedgerEntry {
  id              String     @id @default(uuid()) @db.Uuid
  tableId         String     @map("table_id") @db.Uuid
  playerSessionId String?    @map("player_session_id") @db.Uuid
  dealerSessionId String?    @map("dealer_session_id") @db.Uuid
  type            LedgerType
  amount          Decimal    @db.Decimal(12, 2) // positive; adjustments may be negative
  category        String? // 'uber','food','other' for reimbursements
  note            String?
  occurredAt      DateTime   @default(now()) @map("occurred_at")
  createdAt       DateTime   @default(now()) @map("created_at")

  table         Table          @relation(fields: [tableId], references: [id], onDelete: Cascade)
  playerSession PlayerSession? @relation(fields: [playerSessionId], references: [id], onDelete: Cascade)
  dealerSession DealerSession? @relation(fields: [dealerSessionId], references: [id], onDelete: Cascade)

  @@index([tableId])
  @@index([playerSessionId])
  @@index([dealerSessionId])
  @@map("ledger_entries")
}

// Host's own costs for a game.
model HostCost {
  id        String   @id @default(uuid()) @db.Uuid
  gameId    String   @map("game_id") @db.Uuid
  category  String // 'rent','food','other'
  amount    Decimal  @db.Decimal(12, 2)
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@map("host_costs")
}

// Game-level point checkout / settlement, incl. ad-hoc "other" parties.
model Settlement {
  id             String    @id @default(uuid()) @db.Uuid
  gameId         String    @map("game_id") @db.Uuid
  partyType      PartyType @map("party_type")
  partyId        String?   @map("party_id") @db.Uuid // player/dealer id; null for 'other'
  label          String?
  checkinAt      DateTime? @map("checkin_at")
  checkinAmount  Decimal?  @map("checkin_amount") @db.Decimal(12, 2)
  checkoutAt     DateTime? @map("checkout_at")
  checkoutAmount Decimal?  @map("checkout_amount") @db.Decimal(12, 2)
  net            Decimal?  @db.Decimal(12, 2)
  note           String?
  createdAt      DateTime  @default(now()) @map("created_at")

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@map("settlements")
}

// Player insurance on a strong hand: premium paid in, payout on a bad beat.
// Folds into the host take and the player's settlement net.
model Insurance {
  id        String   @id @default(uuid()) @db.Uuid
  gameId    String   @map("game_id") @db.Uuid
  playerId  String?  @map("player_id") @db.Uuid
  label     String?
  premium   Decimal  @db.Decimal(12, 2)
  payout    Decimal  @default(0) @db.Decimal(12, 2)
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  game   Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player Player? @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([gameId])
  @@map("insurance")
}
